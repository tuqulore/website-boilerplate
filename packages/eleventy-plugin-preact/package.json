{
  "name": "@tuqulore-inc/eleventy-plugin-preact",
  "version": "3.0.0",
  "description": "Eleventy plugin for Preact server-side rendering with JSX/MDX support",
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "preact",
    "jsx",
    "mdx",
    "ssr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuqulore/website-boilerplate.git",
    "directory": "packages/eleventy-plugin-preact"
  },
  "license": "MIT",
  "author": "tuqulore inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./eleventy": {
      "types": "./eleventy.d.ts",
      "default": "./eleventy.mjs"
    },
    "./loaders/mdx": {
      "default": "./loaders/mdx.mjs"
    },
    "./loaders/jsx": {
      "default": "./loaders/jsx.mjs"
    }
  },
  "main": "./index.mjs",
  "files": [
    "README.md",
    "index.d.ts",
    "index.mjs",
    "eleventy.d.ts",
    "eleventy.mjs",
    "loaders"
  ],
  "scripts": {
    "lint": "eslint --fix .",
    "test": "node --test"
  },
  "dependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-react": "^7.26.3",
    "@mdx-js/node-loader": "^3.1.0",
    "esbuild": "^0.27.0",
    "preact-render-to-string": "^6.5.13"
  },
  "devDependencies": {
    "@tuqulore-inc/eslint-config": "workspace:*",
    "eslint": "^9.39.2"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0",
    "preact": ">=10.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
