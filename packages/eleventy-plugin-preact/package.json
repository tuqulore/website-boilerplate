{
  "name": "@tuqulore-inc/eleventy-plugin-preact",
  "version": "5.1.1-alpha.0",
  "description": "Eleventy plugin for Preact server-side rendering with JSX/MDX support",
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "preact",
    "jsx",
    "mdx",
    "ssr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuqulore/website-boilerplate.git",
    "directory": "packages/eleventy-plugin-preact"
  },
  "license": "MIT",
  "author": "tuqulore inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./eleventy": {
      "types": "./eleventy.d.ts",
      "default": "./eleventy.js"
    },
    "./loaders/mdx": {
      "default": "./loaders/mdx.js"
    },
    "./loaders/jsx": {
      "default": "./loaders/jsx.js"
    }
  },
  "main": "./index.js",
  "files": [
    "README.md",
    "index.d.ts",
    "index.js",
    "eleventy.d.ts",
    "eleventy.js",
    "loaders"
  ],
  "scripts": {
    "lint": "eslint --fix .",
    "test": "node --test"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "oxc-transform": "^0.139.0",
    "preact-render-to-string": "^6.5.13",
    "satteri": "^0.9.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tuqulore-inc/eslint-config": "workspace:*",
    "eslint": "^10.0.0"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0",
    "preact": ">=10.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
