{
  "name": "my-eleventy-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production run-s clean build:eleventy",
    "build:eleventy": "dotenv -c production -- eleventy",
    "clean": "shx rm -rf dist",
    "dev": "dotenv -c development -- eleventy --serve",
    "format": "prettier --write .",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@eslint/js": "^10.0.0",
    "@iconify/json": "^2.2.90",
    "@iconify/tailwind4": "^1.0.6",
    "@jumpu-ui/tailwindcss": "2.0.0",
    "@tailwindcss/postcss": "^4.0.14",
    "@tailwindcss/typography": "0.5.19",
    "@tuqulore-inc/eleventy-preset": "^4.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mdx": "^3.2.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^17.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "preact": "^10.26.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shx": "^0.4.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18"
  },
  "engines": {
    "node": ">=20"
  }
}
