{
  "name": "my-eleventy-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production run-s clean build:eleventy",
    "build:eleventy": "dotenv -c production -- eleventy",
    "clean": "shx rm -rf dist",
    "dev": "dotenv -c development -- eleventy --serve",
    "format": "oxfmt",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@iconify/json": "^2.2.90",
    "@iconify/tailwind4": "^1.0.6",
    "@jumpu-ui/tailwindcss": "3.0.1",
    "@preact/signals": "^2.9.3",
    "@tailwindcss/postcss": "^4.0.14",
    "@tailwindcss/typography": "0.5.20",
    "@tuqulore-inc/eleventy-preset": "^5.2.0",
    "dotenv-cli": "^11.0.0",
    "npm-run-all2": "^9.0.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "postcss": "^8.5.6",
    "preact": "^10.26.4",
    "shx": "^0.4.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18"
  },
  "engines": {
    "node": ">=20"
  }
}
