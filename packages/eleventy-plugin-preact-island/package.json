{
  "name": "@tuqulore-inc/eleventy-plugin-preact-island",
  "version": "5.1.1-alpha.0",
  "description": "Eleventy plugin for Preact partial hydration with is-land",
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "preact",
    "is-land",
    "partial-hydration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuqulore/website-boilerplate.git",
    "directory": "packages/eleventy-plugin-preact-island"
  },
  "license": "MIT",
  "author": "tuqulore inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./island": {
      "types": "./island.d.ts",
      "default": "./island.js"
    }
  },
  "main": "./index.js",
  "files": [
    "README.md",
    "index.d.ts",
    "index.js",
    "island.d.ts",
    "island.js",
    "resolver.d.ts",
    "resolver.js"
  ],
  "scripts": {
    "lint": "eslint --fix .",
    "test": "node --test",
    "test:types": "tsd"
  },
  "dependencies": {
    "@11ty/is-land": "^5.0.0",
    "devalue": "^5.8.1",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@tuqulore-inc/eslint-config": "workspace:*",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.0",
    "preact": "^10.26.4",
    "preact-render-to-string": "^6.5.13",
    "tsd": "^0.32.0",
    "typescript": "^7.0.0"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0",
    "preact": ">=10.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "tsd": {
    "directory": "test-d",
    "compilerOptions": {
      "strict": true,
      "moduleResolution": "bundler",
      "module": "esnext",
      "target": "es2022",
      "jsx": "react-jsx",
      "jsxImportSource": "preact",
      "noUncheckedIndexedAccess": true
    }
  }
}
