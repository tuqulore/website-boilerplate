    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mdx": "^3.2.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^17.0.0",
    "npm-run-all2": "^9.0.0",
