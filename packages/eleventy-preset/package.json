{
  "name": "@tuqulore-inc/eleventy-preset",
  "version": "5.1.1-alpha.0",
  "description": "Eleventy preset for building static sites with Preact JSX/MDX templates, partial hydration, and PostCSS",
  "keywords": [
    "eleventy",
    "eleventy-preset",
    "postcss",
    "preact"
  ],
  "license": "MIT",
  "author": "tuqulore inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuqulore/website-boilerplate.git",
    "directory": "packages/eleventy-preset"
  },
  "files": [
    "README.md",
    "index.d.ts",
    "index.js",
    "eleventy.d.ts",
    "eleventy.js",
    "island.d.ts",
    "island.js"
  ],
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./eleventy": {
      "types": "./eleventy.d.ts",
      "default": "./eleventy.js"
    },
    "./island": {
      "types": "./island.d.ts",
      "default": "./island.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@tuqulore-inc/eleventy-plugin-postcss": "workspace:*",
    "@tuqulore-inc/eleventy-plugin-preact": "workspace:*",
    "@tuqulore-inc/eleventy-plugin-preact-island": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@tuqulore-inc/oxlint-config": "workspace:*",
    "oxlint": "^1.75.0"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0",
    "postcss": ">=8.0.0",
    "preact": ">=10.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
