{
  "name": "@tuqulore/eleventy-preset",
  "version": "3.0.0",
  "description": "Eleventy preset for building static sites with Preact JSX/MDX templates, partial hydration, and PostCSS",
  "type": "module",
  "main": "./index.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./eleventy": {
      "types": "./eleventy.d.ts",
      "default": "./eleventy.mjs"
    }
  },
  "files": [
    "README.md",
    "index.d.ts",
    "index.mjs",
    "eleventy.d.ts",
    "eleventy.mjs"
  ],
  "keywords": [
    "eleventy",
    "eleventy-preset",
    "preact",
    "postcss"
  ],
  "author": "tuqulore inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuqulore/website-boilerplate.git",
    "directory": "packages/eleventy-preset"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@tuqulore/eleventy-plugin-postcss": "workspace:*",
    "@tuqulore/eleventy-plugin-preact": "workspace:*",
    "@tuqulore/eleventy-plugin-preact-island": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "scripts": {
    "lint": "eslint --fix ."
  },
  "devDependencies": {
    "@tuqulore/eslint-config": "workspace:*",
    "eslint": "9.39.2"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=3.0.0",
    "postcss": ">=8.0.0",
    "preact": ">=10.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
